rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isRole(role) { return request.auth.token.role == role; }
    function isJeff() { return request.auth.uid == 'jeff' || isRole('jeff'); }

    match /{document=**} {
      allow read, write: if false;
    }

    // users: jeff only
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isJeff();
    }

    // scale_groups: jeff, gr3c
    match /scale_groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isJeff() || isRole('gr3c'));
    }
    
    // escala_items: jeff, 3clog, 3cmot, gr3c (specific fields managed in app, rules can stay broad per role for write)
    match /escala_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isJeff() || isRole('3clog') || isRole('3cmot') || isRole('gr3c'));
    }
    
    // checklists: jeff, gr3c
    match /checklists/{placa} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isJeff() || isRole('gr3c'));
    }
    
    // notifications: anyone can create, jeff can clear/delete
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isSignedIn() && isJeff();
    }

    // chat_messages: jeff, 3clog, 3cmot, gr3c
    match /chat_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isJeff() || isRole('3clog') || isRole('3cmot') || isRole('gr3c'));
    }
    
    // company_principles / about: jeff only
    match /company_principles/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isJeff();
    }
  }
}
